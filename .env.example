# Copy to .env and fill in. .env is git-ignored — never commit real values.
# See DEPLOYMENT.md (Part 1 — Infrastructure) for what these mean.

# --- Iteration 1 (agent) ---
AWS_REGION=us-east-1
# A Bedrock model id you have access to in the region above (access is opt-in
# per model in the Bedrock console). Example shown; change to yours.
BEDROCK_MODEL_ID=anthropic.claude-3-5-haiku-20241022-v1:0

# --- Later iterations (kept here for reference; not used until then) ---
# MEMORY_ID=               # Iteration 2: the created AgentCore Memory resource
# ACTOR_ID=                # Iteration 3: usually generated per run (timestamped)
# SESSION_ID=              # Iteration 3: usually generated per run (timestamped)

# --- Testing ---
# Set to 1 to make the smoke test hit real Bedrock (costs a little, needs creds).
# Unset/0 = the smoke test uses a mock model (free, offline).
# RUN_LIVE=0
