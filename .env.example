# Copy to .env and fill in. .env is git-ignored — never commit real values.
# See AGENTS.md (Setup & common commands / Infrastructure & deploy) for what these mean.

# --- Iteration 1 (agent) ---
AWS_REGION=us-east-1
# A Bedrock model id you have access to in the region above (access is opt-in
# per model in the Bedrock console). Newer Claude models use a cross-region
# inference profile (the "us." prefix), not the bare foundation-model id.
# Find yours with: aws bedrock list-inference-profiles
BEDROCK_MODEL_ID=us.anthropic.claude-haiku-4-5-20251001-v1:0
# Sampling temperature (0-1). Default 0 keeps runs reproducible for the sweep
# harness (Iteration 5) so a recall change is attributable to the memory param,
# not sampling noise. Leave unset to use the default of 0.
# BEDROCK_TEMPERATURE=0

# --- Iteration 2 (memory) ---
# From `terraform output memory_id`. The namespace must match the strategy's
# (terraform output memory_namespace) or recall silently returns nothing.
MEMORY_ID=agent_memory_lab-xxxxxxxxxx
MEMORY_NAMESPACE=semantic/{actorId}

# --- Iteration 3 (attach memory) ---
# Who the memories belong to / which conversation. Usually generated per run, so
# leave unset and the agent makes a fresh actor-/session- id each run. Set them to
# pin a conversation across turns (e.g. to recall a fact stored in an earlier run).
# ACTOR_ID=
# SESSION_ID=
# Set to 0 to run the no-memory baseline (control): memory attachment is skipped.
# MEMORY_ENABLED=1

# --- Testing ---
# Set to 1 to make the smoke test hit real Bedrock (costs a little, needs creds).
# Unset/0 = the smoke test uses a mock model (free, offline).
# RUN_LIVE=0
